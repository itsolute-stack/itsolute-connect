# API app config (apps/api). Loaded via Node's built-in process.loadEnvFile().
NODE_ENV="development"
PORT="4000"

# Postgres — shared with @itsolute/db
DATABASE_URL="postgresql://user:password@localhost:5432/itsolute_connect?schema=public"

# Auth (shared secret with the dashboard so sessions verify across both)
AUTH_SECRET=""

# Plivo (voice). Auth token verifies inbound webhook signatures (V3).
PLIVO_AUTH_ID=""
PLIVO_AUTH_TOKEN=""
# Public base URL Plivo uses to reach this API, no trailing slash.
# Needed to reconstruct the exact URL for signature checks behind a proxy.
PLIVO_WEBHOOK_BASE_URL="https://api.itsolute.com"
# Local testing only: bypass signature verification.
PLIVO_SKIP_SIGNATURE="false"

# Redis / BullMQ (recovery queue + worker). Unset in dev = queue no-ops so
# webhooks still work without Redis. Required in production.
REDIS_URL="redis://localhost:6379"

# Existing WhatsApp platform (internal send API). Auth = x-webhook-secret header
# matching that platform's INTERNAL_WEBHOOK_SECRET. Unset base URL = mock mode
# (logs + fake message id) so the recovery pipeline runs without the platform.
WA_PLATFORM_BASE_URL=""
WA_PLATFORM_SECRET=""
WA_PLATFORM_SEND_PATH="/api/notify/custom"

# Status/reply ingestion (worker process). WebSocket for real-time + a REST poll
# to reconcile gaps (matched by waMessageId). REST needs a platform login.
WA_PLATFORM_WS_URL=""              # e.g. wss://wa.host/ws
WA_PLATFORM_USER_EMAIL=""
WA_PLATFORM_USER_PASSWORD=""
RECONCILE_INTERVAL_MS="180000"     # 3 min
RECONCILE_WINDOW_HOURS="72"
