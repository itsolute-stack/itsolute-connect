# Postgres — Supabase. Two URLs (recommended for serverless):
#
# DATABASE_URL = Supabase TRANSACTION pooler (port 6543) + ?pgbouncer=true — used
#   by the app at runtime; multiplexes connections so serverless doesn't exhaust
#   the pool ("max clients reached in session mode").
# DIRECT_URL   = Supabase SESSION pooler (port 5432) or direct — used ONLY by
#   `prisma migrate` (migrations can't run through pgbouncer). Only needs to be
#   set where migrations run.
DATABASE_URL="postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:5432/postgres"
