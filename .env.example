# --- Database (shared) ---
# Runtime = Supabase TRANSACTION pooler (6543, ?pgbouncer=true). Migrations use DIRECT_URL.
DATABASE_URL="postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- Auth ---
# 32+ byte random secret for signing session tokens. Generate: openssl rand -base64 48
AUTH_SECRET=""
# Session lifetime
SESSION_TTL_HOURS="720"

# --- Redis / BullMQ (Railway) ---
REDIS_URL="redis://localhost:6379"

# --- Plivo (voice) ---
PLIVO_AUTH_ID=""
PLIVO_AUTH_TOKEN=""

# --- Existing WhatsApp platform (internal send API) ---
# Auth = x-webhook-secret header matching the platform's INTERNAL_WEBHOOK_SECRET.
WA_PLATFORM_BASE_URL=""
WA_PLATFORM_SECRET=""
WA_PLATFORM_SEND_PATH="/api/notify/custom"

# --- App URLs ---
DASHBOARD_URL="http://localhost:3000"
API_BASE_URL="http://localhost:4000"
